# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=prod            # dev | staging | prod
DEBUG=false

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_DIR_PATH=logs
LOG_FORMAT=json             # json (prod) | text (dev)
LOGTAIL_TOKEN=              # Optional

# ─── Auth (JWT single-user fallback) ─────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
AUTH_SECRET_KEY=change-me-with-openssl-rand-hex-32
AUTH_ALGORITHM=HS256
AUTH_EXPIRES_IN=30

# ─── API ─────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# ─── AFIP WSN ────────────────────────────────────────────────────────────────
CERTIFICATE_PATH=/app/credentials/cert.crt
PRIVATE_KEY_PATH=/app/credentials/private_key.key
PASSPHRASE=                 # Optional

# ─── Rate limiting (slowapi) ─────────────────────────────────────────────────
RATE_LIMIT_TIME=60
MAX_CALLS=60
